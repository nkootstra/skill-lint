{
  "name": "skill-lint",
  "version": "1.0.0",
  "description": "GitHub Action that evaluates, benchmarks, and refines agent skills in PRs",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-action",
    "skill-lint",
    "agent-skills",
    "evaluation",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "yaml": "^2.7.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "eslint": "^9.16.0"
  }
}
