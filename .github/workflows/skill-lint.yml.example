# Example workflow: Add this to your repository as .github/workflows/skill-lint.yml
name: Skill Lint

on:
  pull_request:
    paths:
      - "skills/**"
      - ".skill-lint.yml"

permissions:
  contents: read
  pull-requests: write
  checks: write

jobs:
  lint-skills:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0  # Needed for A/B comparison with base branch

      # Option 1: Use with Anthropic API
      - uses: nkootstra/skill-lint@main
        with:
          provider: anthropic
          model: claude-sonnet-4-20250514
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}

      # Option 2: Use with OpenAI
      # - uses: nkootstra/skill-lint@main
      #   with:
      #     provider: openai
      #     model: gpt-4o
      #     openai_api_key: ${{ secrets.OPENAI_API_KEY }}

      # Option 3: Use with LiteLLM
      # - uses: nkootstra/skill-lint@main
      #   with:
      #     provider: litellm
      #     model: "anthropic/claude-sonnet-4-20250514"
      #     litellm_api_key: ${{ secrets.LITELLM_API_KEY }}
      #     litellm_api_base: "https://your-litellm-proxy.com"

      # Option 4: Use with Claude Code (Max/Pro subscription)
      # - uses: nkootstra/skill-lint@main
      #   with:
      #     provider: claude-code
